# --- RabbitMQ ---
RABBITMQ_USER=observ
RABBITMQ_PASS=observ
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_VHOST=/

# --- Elasticsearch ---
ELASTICSEARCH_URL=http://elasticsearch:9200
ELASTICSEARCH_USER=
ELASTICSEARCH_PASSWORD=

# --- API ---
API_HOST=0.0.0.0
API_PORT=8000
API_DATABASE_URL=sqlite:////data/app.db
API_CORS_ORIGINS=http://localhost:5173,http://localhost:8080
API_LOG_LEVEL=INFO

# --- Worker ---
WORKER_PREFETCH=32
WORKER_POLL_INTERVAL_SECONDS=10
WORKER_MAX_RETRIES=3

# --- Frontend (build-time) ---
VITE_API_BASE_URL=http://localhost:8000
